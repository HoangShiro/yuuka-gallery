{
    "id": "discord-bot",
    "name": "Discord Bot Manager",
    "version": "0.1.0",
    "author": "Yuuka",
    "description": "Manage per-user Discord bots with isolated console, optional modules, and lifecycle controls.",
    "static_folder": "static",
    "entry_points": {
        "backend": "backend:DiscordBotPlugin",
        "frontend_component": "DiscordBotComponent"
    },
    "assets": {
        "js": [
            "utils/formatting.js",
            "utils/dom.js",
            "utils/module.js",
            "pages/policy_manager.js",
            "pages/character_picker.js",
            "pages/image_gen_config.js",
            "pages/tts_engine_picker.js",
            "pages/brain_abilities.js",
            "pages/rag_search_config.js",
            "pages/dashboard.js",
            "discord_bot.js"
        ],
        "css": [
            "discord_bot.css"
        ]
    },
    "dependencies": {
        "python": [],
        "node": [
            "discord.js@^14.22.1"
        ]
    },
    "ui": {
        "tab": {
            "id": "discord-bot",
            "label": "Discord Bot",
            "icon": "smart_toy"
        },
        "order": 45
